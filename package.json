{
  "name": "@agent-score/sdk",
  "version": "1.9.0",
  "description": "TypeScript client for the AgentScore trust and reputation API",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "agentscore",
    "x402",
    "erc-8004",
    "agent",
    "trust",
    "reputation",
    "wallet",
    "blockchain",
    "ai-agent",
    "agentic-payments",
    "mcp",
    "middleware"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentscore/node-sdk"
  },
  "homepage": "https://agentscore.sh",
  "bugs": {
    "url": "https://github.com/agentscore/node-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "lefthook": "^2.1.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
